# Copia questo file in ".env" e personalizza i valori prima di avviare l'app in produzione.

# Password per accedere al pannello "Ufficio" (gestione dipendenti, cantieri, report ore).
# Cambiala sempre prima di andare online!
ADMIN_PASSWORD=cambia-questa-password

# Porta su cui parte il server (la maggior parte dei servizi di hosting la impostano automaticamente).
PORT=3000
